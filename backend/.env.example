# ── InChina Backend Configuration ──

# Server
PORT=3000

# Admin password (hashed with bcrypt)
# Generate with: node hash-password.js YourPassword123
ADMIN_PASSWORD=$2b$12$REPLACE_WITH_ACTUAL_HASH

# JWT secret for admin sessions
JWT_SECRET=replace-with-random-string-at-least-32-chars

# Telegram Bot
# 1. Create bot via @BotFather in Telegram
# 2. Paste the token here
TELEGRAM_BOT_TOKEN=

# Telegram chat IDs to receive notifications about new leads
# Comma-separated. To find your chat ID: send /start to your bot,
# then visit https://api.telegram.org/bot<TOKEN>/getUpdates
NOTIFY_CHAT_IDS=
